# Base de datos usada por Docker Compose
POSTGRES_DB=sistema_pedidos
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me

# El host "postgres" es el nombre del servicio en docker-compose.yml
DATABASE_URL=postgresql://admin:change_me@postgres:5432/sistema_pedidos

JWT_SECRET=change_me_in_production
# Solo para ejecutar el seed de desarrollo. En producción se omiten por defecto.
SEED_DEMO_PASSWORD=123456
PORT=3000
CLIENT_URL=http://localhost

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me
MINIO_BUCKET_PRODUCTOS=productos
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_PUBLIC_READ=true

VITE_API_URL=/api
