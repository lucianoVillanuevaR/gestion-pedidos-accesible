# Configuración local para Docker Compose.
# En producción cambia POSTGRES_PASSWORD, JWT_SECRET y las claves de MinIO.

# Base de datos usada por Docker Compose.
POSTGRES_DB=sistema_pedidos
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# El host "postgres" es el nombre del servicio dentro de Docker.
# No uses localhost:5433 en DATABASE_URL cuando levantes con docker compose.
DATABASE_URL=postgresql://admin:admin123@postgres:5432/sistema_pedidos

PORT=3000
CLIENT_URL=http://localhost
JWT_SECRET=cambiar_esta_clave_en_produccion_por_una_larga_y_segura

# Usuarios demo creados automáticamente por docker compose up.
SEED_DEMO_PASSWORD=123456

# MinIO para imágenes de productos.
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_PRODUCTOS=productos
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_PUBLIC_READ=true

# Frontend. En Docker se usa /api porque Nginx redirige al backend.
VITE_API_URL=/api
VITE_MINIO_PUBLIC_URL=http://localhost:9000
VITE_MINIO_BUCKET_PRODUCTOS=productos
