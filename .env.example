# Base de datos usada por Docker Compose
POSTGRES_DB=sistema_pedidos
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# Docker usa el servicio postgres y su puerto interno 5432.
# Sin Docker, desde el host, usar localhost:5433.
DATABASE_URL=postgresql://admin:admin123@postgres:5432/sistema_pedidos

# Valores de demostración: cambiar contraseña y JWT_SECRET antes de publicar.
JWT_SECRET=change_me_in_production_use_a_long_random_value
SEED_DEMO_USERS=true
SEED_DEMO_PASSWORD=123456
PORT=3000
CLIENT_URL=http://localhost

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123456
MINIO_BUCKET_PRODUCTOS=productos
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_PUBLIC_READ=true

VITE_API_URL=/api
